rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Admin access: Multiple admins authorized
    match /{document=**} {
      allow read, write: if request.auth != null && 
        (request.auth.token.email == 'jhxox666@gmail.com' || 
         request.auth.token.email == 'jhxox666@test.com' || 
         request.auth.token.email == 'sungho4768@gmail.com');
    }

    // [TEMPORARY TEST] Allow anyone to read users to diagnose visibility issue
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.uid);
    }
    
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /trial_logs/{hwid} {
      allow read, write: if true;
    }
    
    match /activeSessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
